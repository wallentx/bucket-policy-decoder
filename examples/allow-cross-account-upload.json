{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPartnerUpload",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "111122223333"
        ]
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::shared-ingest-bucket/uploads/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    }
  ]
}
