{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyWrongStorageClass",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::archive-ingest/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-storage-class": "STANDARD_IA"
        }
      }
    }
  ]
}
